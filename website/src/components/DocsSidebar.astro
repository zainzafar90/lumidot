---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const sections = [
  {
    items: [
      { label: 'Getting Started', href: '/docs/getting-started' },
    ],
  },
  {
    title: 'API',
    items: [
      { label: 'Lumidot', href: '/docs/spinner' },
    ],
  },
  {
    title: 'Guides',
    items: [
      { label: 'Styling', href: '/docs/styling' },
    ],
  },
];

function isActive(href: string) {
  return currentPath === href || currentPath === href + '/';
}
---

<aside class="hidden md:block w-52 shrink-0 border-r border-zinc-200 dark:border-zinc-800 py-10 pr-6">
  <nav class="sticky top-20 flex flex-col gap-6">
    {sections.map((section) => (
      <div>
        {section.title && (
          <div class="font-mono text-[10px] font-medium tracking-widest uppercase text-zinc-400 dark:text-zinc-600 mb-2">
            {section.title}
          </div>
        )}
        <ul class="flex flex-col gap-0.5">
          {section.items.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block text-[13px] px-3 py-1.5 transition-colors',
                  isActive(item.href)
                    ? 'bg-zinc-100 dark:bg-zinc-900 text-zinc-950 dark:text-zinc-50 font-medium'
                    : 'text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-900/50 hover:text-zinc-950 dark:hover:text-zinc-50',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>
